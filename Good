<!DOCTYPE html>
<html lang="hi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Navi AI - Fixed Interface</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { background-color: #131314; color: #e3e3e3; overflow: hidden; }
        /* Messages scrollable area */
        #chat-container {
            height: calc(100vh - 160px); /* Header aur Input ki jagah chhod kar */
            overflow-y: auto;
        }
        /* Input box fixed at bottom */
        .fixed-bottom {
            position: fixed;
            bottom: 0;
            left: 256px; /* Sidebar width */
            right: 0;
            background: linear-gradient(to top, #131314 70%, transparent);
            padding-bottom: 20px;
        }
        @media (max-width: 768px) { .fixed-bottom { left: 0; } }
        
        .bank-mode { border: 2px solid #ea4335 !important; }
        ::-webkit-scrollbar { width: 5px; }
        ::-webkit-scrollbar-thumb { background: #3c4043; border-radius: 10px; }
    </style>
</head>
<body class="flex h-screen">

    <aside class="w-64 bg-[#1e1f20] border-r border-gray-800 flex flex-col hidden md:flex z-20">
        <div class="p-4">
            <button onclick="location.reload()" class="bg-[#28292a] hover:bg-[#333537] px-4 py-3 rounded-full text-sm w-full text-left">+ New Chat</button>
        </div>
        <div id="history-list" class="flex-1 overflow-y-auto px-4 text-xs text-gray-500 space-y-2">
            <p class="font-bold uppercase tracking-widest py-4">Memory Vault</p>
        </div>
        <div class="p-4 text-[10px] text-cyan-500 font-mono border-t border-gray-800">🛡️ NAVI SECURE</div>
    </aside>

    <main class="flex-1 flex flex-col relative">
        <header class="h-16 flex items-center justify-between px-8 z-10 bg-[#131314]">
            <div class="text-xl text-gray-400">Navi AI</div>
            <div id="bank-guard" class="hidden text-red-500 text-xs font-bold border border-red-800 px-3 py-1 rounded-full bg-red-900/10">🚫 BANK MODE ACTIVE</div>
            <button onclick="toggleSettings()" class="p-2 hover:bg-gray-800 rounded-full">⚙️</button>
        </header>

        <div id="chat-container" class="px-4 md:px-24 py-4 space-y-6">
            <div id="welcome" class="text-center mt-20">
                <h1 class="text-4xl font-semibold bg-gradient-to-r from-blue-400 via-purple-400 to-red-400 bg-clip-text text-transparent">Hello, Main Navi Hoon</h1>
                <p class="text-gray-500 mt-4">Main aapka honest assistant hoon jo privacy nahi todta.</p>
            </div>
        </div>

        <div class="fixed-bottom px-4 md:px-24">
            <div id="input-ui" class="max-w-3xl mx-auto bg-[#1e1f20] border border-transparent focus-within:border-gray-600 rounded-[28px] p-4 shadow-2xl transition-all">
                <textarea id="userInput" rows="1" class="w-full bg-transparent border-none outline-none text-lg resize-none placeholder-gray-500 overflow-hidden" placeholder="Yahan poochein..." oninput="this.style.height='auto';this.style.height=this.scrollHeight+'px'"></textarea>
                <div class="flex justify-between items-center mt-2">
                    <div class="flex gap-4 text-gray-400">
                        <button onclick="alert('Writer Mode Active')" title="Writer Mode">✍️</button>
                    </div>
                    <button onclick="sendToNavi()" class="bg-blue-600 hover:bg-blue-500 text-white px-6 py-1.5 rounded-full font-bold">Analyze</button>
                </div>
            </div>
            <p class="text-[9px] text-center text-gray-600 mt-2">Navi hamesha direct aur honest jawaab dega.</p>
        </div>
    </main>

    <div id="settings" class="hidden fixed inset-0 bg-black/80 flex items-center justify-center z-50 p-4">
        <div class="bg-[#1e1f20] p-6 rounded-3xl w-full max-w-md border border-gray-700">
            <h2 class="text-xl font-bold mb-4">OpenRouter Config</h2>
            <input type="password" id="api-key" class="w-full bg-[#131314] border border-gray-700 p-3 rounded-xl mb-4 text-white" placeholder="API Key">
            <div class="flex justify-end gap-2">
                <button onclick="toggleSettings()" class="px-4 py-2 text-gray-400">Cancel</button>
                <button onclick="saveSettings()" class="bg-blue-600 px-6 py-2 rounded-xl text-white">Save</button>
            </div>
        </div>
    </div>

    <script>
        function toggleSettings() { document.getElementById('settings').classList.toggle('hidden'); }
        function saveSettings() {
            localStorage.setItem('navi_key', document.getElementById('api-key').value);
            toggleSettings();
        }

        async function sendToNavi() {
            const input = document.getElementById('userInput').value.trim();
            if(!input) return;

            document.getElementById('welcome').classList.add('hidden');
            const chatContainer = document.getElementById('chat-container');
            
            // UI Update
            chatContainer.innerHTML += `<div class="flex justify-end mb-4"><div class="bg-[#2b2c2d] p-4 rounded-2xl max-w-[80%]">${input}</div></div>`;
            document.getElementById('userInput').value = "";
            document.getElementById('userInput').style.height = "auto";

            // Bank Guard Logic
            if(input.toLowerCase().includes("bank")) {
                document.getElementById('bank-guard').classList.remove('hidden');
                document.getElementById('input-ui').classList.add('bank-mode');
                chatContainer.innerHTML += `<div class="text-red-400 text-xs italic">Navi: Security alert! Bank details detect hui hain, main ise yaad nahi rakhunga.</div>`;
            }

            // API Logic
            const key = localStorage.getItem('navi_key');
            if(!key) { alert("Pehle settings mein API key daalein"); toggleSettings(); return; }

            try {
                const response = await fetch("https://openrouter.ai/api/v1/chat/completions", {
                    method: "POST",
                    headers: { "Authorization": `Bearer ${key}`, "Content-Type": "application/json" },
                    body: JSON.stringify({ model: "google/gemini-pro", messages: [{role: "user", content: input}] })
                });
                const data = await response.json();
                const reply = data.choices[0].message.content;
                chatContainer.innerHTML += `<div class="flex justify-start mb-4"><div class="p-2 max-w-[90%] leading-relaxed">${reply.replace(/\n/g, '<br>')}</div></div>`;
            } catch(e) {
                chatContainer.innerHTML += `<div class="text-red-500 text-xs">Error: Connection failed.</div>`;
            }
            chatContainer.scrollTop = chatContainer.scrollHeight;
        }
    </script>
</body>
</html>
