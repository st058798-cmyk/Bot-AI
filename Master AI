<!DOCTYPE html>
<html lang="hi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Navi AI Master Core</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { background-color: #131314; color: #e3e3e3; overflow: hidden; font-family: 'Google Sans', sans-serif; }
        
        /* Chat History Scroll Area */
        #main-chat-area {
            height: calc(100vh - 180px); 
            overflow-y: auto;
            scroll-behavior: smooth;
        }

        /* Fixed Gemini-style Bottom Input */
        .input-wrapper {
            position: fixed;
            bottom: 0;
            left: 260px; /* Sidebar width */
            right: 0;
            background: linear-gradient(to top, #131314 80%, transparent);
            padding: 20px 0 30px 0;
            z-index: 100;
        }
        @media (max-width: 768px) { .input-wrapper { left: 0; } }

        .input-container {
            background-color: #1e1f20;
            border-radius: 28px;
            max-width: 800px;
            margin: 0 auto;
            padding: 12px 20px;
            border: 1px solid transparent;
            transition: border 0.3s ease;
        }
        .input-container:focus-within { border-color: #5f6368; }
        .bank-alert-border { border: 2px solid #ea4335 !important; box-shadow: 0 0 15px rgba(234, 67, 53, 0.3); }

        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-thumb { background: #3c4043; border-radius: 10px; }
    </style>
</head>
<body class="flex h-screen">

    <aside class="w-[260px] bg-[#1e1f20] flex flex-col hidden md:flex border-r border-gray-800">
        <div class="p-4">
            <button onclick="location.reload()" class="flex items-center gap-3 bg-[#28292a] hover:bg-[#333537] px-4 py-3 rounded-full text-sm font-medium w-full transition-all">
                <span class="text-xl">+</span> Nayi Chat
            </button>
        </div>
        <div class="flex-1 overflow-y-auto px-4 mt-6">
            <h3 class="text-[10px] text-gray-500 uppercase font-bold tracking-[2px] mb-4">Memory History</h3>
            <div id="history-list" class="space-y-1 text-sm text-gray-300">
                </div>
        </div>
        <div class="p-6 border-t border-gray-800">
            <div class="flex items-center gap-2 text-cyan-500 text-[10px] font-mono tracking-widest">
                <span class="w-2 h-2 bg-cyan-500 rounded-full animate-pulse"></span>
                NAVI CORE SECURE
            </div>
        </div>
    </aside>

    <main class="flex-1 flex flex-col relative">
        <header class="h-16 flex items-center justify-between px-8 bg-[#131314] z-50">
            <div class="text-xl font-medium text-gray-300">Navi Assistant</div>
            <div id="security-badge" class="hidden flex items-center gap-2 bg-red-900/20 text-red-500 px-4 py-1 rounded-full border border-red-900/50 text-[10px] font-bold">
                🚫 PRIVACY LOCK: SENSITIVE DATA DETECTED
            </div>
            <button onclick="openSettings()" class="p-2 hover:bg-gray-800 rounded-full transition-all text-gray-400">⚙️ Settings</button>
        </header>

        <div id="main-chat-area" class="px-4 md:px-20 py-6 space-y-8">
            <div id="welcome-msg" class="text-center mt-20 max-w-2xl mx-auto">
                <h1 class="text-5xl font-semibold mb-6 bg-gradient-to-r from-[#4285f4] via-[#9b72cb] to-[#d96570] bg-clip-text text-transparent">Namaste, Siddhesar/Chandni</h1>
                <p class="text-[#8e9196] text-lg">Main aapka "Honest Navi AI" hoon. Main aapka data leak nahi hone deta aur hamesha seedhi baat karta hoon.</p>
            </div>
        </div>

        <div class="input-wrapper px-4">
            <div id="input-box-ui" class="input-container shadow-2xl">
                <textarea id="userInput" rows="1" class="w-full bg-transparent border-none outline-none text-lg text-white placeholder-[#8e9196] resize-none py-1 overflow-hidden" placeholder="Yahan poochein ya screen ka context dalein..." oninput="autoExpand(this)"></textarea>
                <div class="flex justify-between items-center mt-3">
                    <div class="flex gap-5 text-gray-400">
                        <button onclick="toggleWriter()" id="writer-btn" title="Writer Mode" class="hover:text-white transition-all text-lg">✍️</button>
                        <button onclick="alert('All-Language Help Active')" title="Language Help" class="hover:text-white transition-all text-lg">🌐</button>
                    </div>
                    <button onclick="sendRequest()" class="bg-blue-600 hover:bg-blue-500 text-white px-6 py-2 rounded-full font-bold text-sm transition-all">Analyze</button>
                </div>
            </div>
            <p class="text-[10px] text-center text-gray-600 mt-3 font-medium tracking-wide">NAVI CORE: NO DATA MANIPULATION • PRIVACY-FIRST AI</p>
        </div>
    </main>

    <div id="settings-modal" class="hidden fixed inset-0 bg-black/90 backdrop-blur-md z-[200] flex items-center justify-center p-4">
        <div class="bg-[#1e1f20] p-8 rounded-[32px] w-full max-w-md border border-gray-800">
            <h2 class="text-2xl font-bold mb-6">Navi System Config</h2>
            <div class="space-y-4">
                <input type="password" id="api-key-val" class="w-full bg-[#131314] border border-gray-700 p-4 rounded-2xl text-white outline-none focus:border-blue-500" placeholder="OpenRouter API Key">
                <input type="text" id="model-val" class="w-full bg-[#131314] border border-gray-700 p-4 rounded-2xl text-white outline-none focus:border-blue-500" placeholder="Model (Default: google/gemini-pro)" value="google/gemini-pro">
            </div>
            <div class="mt-8 flex justify-end gap-4">
                <button onclick="openSettings()" class="text-gray-400 font-medium">Baahar</button>
                <button onclick="saveConfig()" class="bg-blue-600 px-8 py-3 rounded-2xl text-white font-bold hover:bg-blue-500">Save System</button>
            </div>
        </div>
    </div>

    <script>
        let writerModeActive = false;

        function autoExpand(el) {
            el.style.height = 'auto';
            el.style.height = el.scrollHeight + 'px';
        }

        function openSettings() { document.getElementById('settings-modal').classList.toggle('hidden'); }
        
        function saveConfig() {
            localStorage.setItem('navi_api_key', document.getElementById('api-key-val').value);
            localStorage.setItem('navi_model_id', document.getElementById('model-val').value);
            openSettings();
        }

        function toggleWriter() {
            writerModeActive = !writerModeActive;
            document.getElementById('writer-btn').style.color = writerModeActive ? "#4285f4" : "#9ca3af";
            alert(writerModeActive ? "Writer Mode Active: Ab main seedhi aur sachi baatein likhunga." : "Writer Mode OFF.");
        }

        async function sendRequest() {
            const input = document.getElementById('userInput').value.trim();
            if(!input) return;

            document.getElementById('welcome-msg').classList.add('hidden');
            const chatArea = document.getElementById('main-chat-area');

            // 1. User Message Display
            chatArea.innerHTML += `<div class="flex justify-end mb-6"><div class="bg-[#2b2c2d] px-5 py-3 rounded-2xl max-w-[80%] text-[16px]">${input}</div></div>`;
            document.getElementById('userInput').value = "";
            document.getElementById('userInput').style.height = "auto";

            // 2. NAVI CORE: Bank & Privacy Check
            if(input.toLowerCase().includes("bank") || input.toLowerCase().includes("account") || input.toLowerCase().includes("password")) {
                document.getElementById('security-badge').classList.remove('hidden');
                document.getElementById('input-box-ui').classList.add('bank-alert-border');
                chatArea.innerHTML += `<div class="flex justify-start mb-6"><div class="text-red-400 text-xs font-mono p-4 border border-red-900 bg-red-900/10 rounded-2xl w-full">⚠️ NAVI_ALERT: Bank Details Detect Hui Hain. Strict Privacy Rule Ke Hisaab Se Main Ise Kisi Server Par Nahi Bhejung Aur Nahi Yaad Rakhunga.</div></div>`;
                return;
            } else {
                document.getElementById('security-badge').classList.add('hidden');
                document.getElementById('input-box-ui').classList.remove('bank-alert-border');
            }

            // 3. API Communication
            const key = localStorage.getItem('navi_api_key');
            if(!key) { alert("Pehle Settings mein API Key daalein."); openSettings(); return; }

            try {
                const model = localStorage.getItem('navi_model_id') || 'google/gemini-pro';
                const response = await fetch("https://openrouter.ai/api/v1/chat/completions", {
                    method: "POST",
                    headers: { "Authorization": `Bearer ${key}`, "Content-Type": "application/json" },
                    body: JSON.stringify({ model: model, messages: [{role: "user", content: input}] })
                });
                const data = await response.json();
                const reply = data.choices[0].message.content;

                // 4. Honest/Direct Response
                chatArea.innerHTML += `<div class="flex justify-start mb-6"><div class="px-5 py-1 text-[16px] text-[#e3e3e3] leading-relaxed w-full">${reply.replace(/\n/g, '<br>')}</div></div>`;
                
                // 5. Save Non-Sensitive History
                saveToMemory(input);
            } catch (err) {
                chatArea.innerHTML += `<div class="text-red-500 text-xs italic">Error: Connection fail. Key check karein.</div>`;
            }
            chatArea.scrollTop = chatArea.scrollHeight;
        }

        function saveToMemory(txt) {
            let hist = JSON.parse(localStorage.getItem('navi_memory')) || [];
            hist.unshift(txt.substring(0, 25) + "...");
            localStorage.setItem('navi_memory', JSON.stringify(hist.slice(0, 10)));
            renderMemory();
        }

        function renderMemory() {
            const list = document.getElementById('history-list');
            list.innerHTML = "";
            let hist = JSON.parse(localStorage.getItem('navi_memory')) || [];
            hist.forEach(h => {
                list.innerHTML += `<div class="p-2 hover:bg-[#2b2c2d] rounded-lg cursor-pointer truncate transition-all opacity-70 hover:opacity-100">${h}</div>`;
            });
        }
        renderMemory();
    </script>
</body>
</html>
